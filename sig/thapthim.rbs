module Thapthim
  VERSION: String

  class Error < StandardError
  end

  # Word-level segmentation. Returns the input split into word tokens.
  def self.word_segment: (untyped input_text, ?normalize: bool) -> Array[String]

  # Syllable-level segmentation. Boundaries are a superset of +word_segment+'s.
  def self.syllable_segment: (untyped input_text, ?normalize: bool) -> Array[String]

  # Thai Character Cluster segmentation — the smallest inseparable units.
  def self.tcc_segment: (untyped input_text) -> Array[String]

  # Character offsets of the TCC boundaries for +input_text+.
  def self.tcc_positions: (untyped input_text) -> Array[Integer]

  # Standard text normalization (spaces, vowel order, zero-width marks, ...).
  def self.std_normalize: (untyped input) -> String
end
